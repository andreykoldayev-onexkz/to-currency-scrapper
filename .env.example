# Пример файла с переменными окружения
# Скопируйте этот файл в .env и заполните своими значениями

# Email настройки
OUTLOOK_EMAIL=your_email@example.com
OUTLOOK_PASSWORD=your_password
TARGET_EMAIL=recipient@example.com

# API настройки
API_URL=https://your-bitrix-url.com/rest/endpoint

# Yandex Object Storage настройки
STORAGE_ENDPOINT=https://storage.yandexcloud.net
STORAGE_BUCKET=your-bucket-name
STORAGE_STATE_KEY=playwright/storage_state.json
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key

# Playwright настройки
PLAYWRIGHT_HEADLESS=1
SELENIUM_WAIT_SECONDS=8
